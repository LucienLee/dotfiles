#!/usr/bin/env bash

# Create a new directory and enter it
function mkd() {
	mkdir -p "$@" && cd "$_";
}

# Use o as open
function o() { test $# = 0 && open . || open "$@"; }

#imagemagick
function gifloop() { convert -loop 0 "$@" "$@"; }

#csie login
function csie {
    if [ -n "$1" ]; then
        ssh r02944010@linux"$1".csie.org
    else
        ssh r02944010@linux15.csie.org
    fi
}

#
function switch_git_ssh() {
  local scalable_ssh="ssh -i ~/.ssh/scalable_rsa";
  local origin_ssh="ssh -i ~/.ssh/id_rsa";
  case $1 in
    scalable)
      if [ "$GIT_SSH_COMMAND" != "$scalable_ssh" ]; then
        export GIT_SSH_COMMAND=$scalable_ssh
        export PS1="${PS1}🖨  \[\033[38;5;6m\]>\[$(tput sgr0)\] "
      fi
      ;;
    origin | *)
      export GIT_SSH_COMMAND=$origin_ssh
      source ~/.dotfiles/system/.prompt
      ;;
  esac
}
complete -W "origin scalable" switch_git_ssh
